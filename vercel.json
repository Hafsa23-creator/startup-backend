{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "MONGO_URI": "@mongo-uri",
    "CLOUD_NAME": "@cloud-name",
    "API_KEY": "@api-key",
    "API_SECRET": "@api-secret"
  }
}